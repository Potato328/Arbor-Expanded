{
  "multipart": [
    {"when":  {"state": "single"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_1"}},
    {"when":  {"state": "single"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_f2"}},

    {"when":  {"state": "top"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_top_1"}},
    {"when":  {"state": "top"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_top_f2"}},
    {"when":  {"state": "bottom"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_bottom_1"}},
    {"when":  {"state": "bottom"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_bottom_f2"}},

    {"when": {"axis":  "z", "state":  "bottom_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_1"}},
    {"when": {"axis":  "z", "state":  "bottom_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_f2"}},
    {"when": {"axis":  "z", "state":  "bottom_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_1", "y":  180}},
    {"when": {"axis":  "z", "state":  "bottom_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_f2", "y":  180}},
    {"when": {"axis":  "z", "state":  "top_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_1"}},
    {"when": {"axis":  "z", "state":  "top_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_f2"}},
    {"when": {"axis":  "z", "state":  "top_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_1", "y": 180}},
    {"when": {"axis":  "z", "state":  "top_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_f2", "y": 180}},

    {"when": {"axis":  "x", "state":  "bottom_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_1", "y": 90, "uvlock": true}},
    {"when": {"axis":  "x", "state":  "bottom_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_f2", "y": 90, "uvlock": true}},
    {"when": {"axis":  "x", "state":  "bottom_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_1", "y": 270, "uvlock": true}},
    {"when": {"axis":  "x", "state":  "bottom_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_f2", "y": 270, "uvlock": true}},
    {"when": {"axis":  "x", "state":  "top_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_1", "y": 90, "uvlock": true}},
    {"when": {"axis":  "x", "state":  "top_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_f2", "y": 90, "uvlock": true}},
    {"when": {"axis":  "x", "state":  "top_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_1", "y": 270, "uvlock": true}},
    {"when": {"axis":  "x", "state":  "top_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_f2", "y": 270, "uvlock": true}},

    {"when": {"axis":  "x|z", "state":  "floor_bottom_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_left_floor_1", "y":  180, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_bottom_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_left_floor_f2", "y":  180, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_bottom_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_right_floor_1", "y":  90, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_bottom_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_bottom_right_floor_f2", "y":  90, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_left_floor_1", "y":  270, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_left"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_left_floor_f2", "y":  270, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_right_floor_1", "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_right"}, "apply": {"model": "portalmodexpanded:block/dirty/dirty_blackplate_corner_top_right_floor_f2", "uvlock": true}}
  ]
}