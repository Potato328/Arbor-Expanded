{
  "multipart": [
    {"when":  {"state": "single"}, "apply": { "model": "portalmod:block/arbored_blackplate"}},
    {"when":  {"state": "single"}, "apply": { "model": "betterarbored:block/3/ab_c"}},
    {"when":  {"state": "single"}, "apply": { "model": "betterarbored:block/3/ab_f"}},

    {"when":  {"state": "top"}, "apply": { "model": "portalmod:block/arbored_blackplate_panel_top"}},
    {"when":  {"state": "top"}, "apply": { "model": "betterarbored:block/3/ab_top_c"}},
    {"when":  {"state": "top"}, "apply": { "model": "betterarbored:block/3/ab_top_f"}},
    {"when":  {"state": "bottom"}, "apply": { "model": "portalmod:block/arbored_blackplate_panel_bottom"}},
    {"when":  {"state": "bottom"}, "apply": { "model": "betterarbored:block/3/ab_bottom_c"}},
    {"when":  {"state": "bottom"}, "apply": { "model": "betterarbored:block/3/ab_bottom_f"}},

    {"when": {"axis":  "z", "state":  "bottom_left"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_corner_bottom"}},
    {"when": {"axis":  "z", "state":  "bottom_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_c"}},
    {"when": {"axis":  "z", "state":  "bottom_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_f"}},
    {"when": {"axis":  "z", "state":  "bottom_right"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_corner_bottom", "y":  180}},
    {"when": {"axis":  "z", "state":  "bottom_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_c", "y":  180}},
    {"when": {"axis":  "z", "state":  "bottom_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_f", "y":  180}},
    {"when": {"axis":  "z", "state":  "top_left"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_corner_top"}},
    {"when": {"axis":  "z", "state":  "top_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_c"}},
    {"when": {"axis":  "z", "state":  "top_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_f"}},
    {"when": {"axis":  "z", "state":  "top_right"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_corner_top", "y": 180}},
    {"when": {"axis":  "z", "state":  "top_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_c", "y":  180}},
    {"when": {"axis":  "z", "state":  "top_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_f", "y":  180}},

    {"when": {"axis":  "x", "state":  "bottom_left"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_corner_bottom", "y": 90}},
    {"when": {"axis":  "x", "state":  "bottom_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_c", "y": 90}},
    {"when": {"axis":  "x", "state":  "bottom_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_f", "y": 90}},
    {"when": {"axis":  "x", "state":  "bottom_right"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_corner_bottom", "y": 270}},
    {"when": {"axis":  "x", "state":  "bottom_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_c", "y": 270}},
    {"when": {"axis":  "x", "state":  "bottom_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_f", "y": 270}},
    {"when": {"axis":  "x", "state":  "top_left"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_corner_top", "y": 90}},
    {"when": {"axis":  "x", "state":  "top_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_c", "y": 90}},
    {"when": {"axis":  "x", "state":  "top_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_f", "y": 90}},
    {"when": {"axis":  "x", "state":  "top_right"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_corner_top", "y": 270}},
    {"when": {"axis":  "x", "state":  "top_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_c", "y": 270}},
    {"when": {"axis":  "x", "state":  "top_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_f", "y": 270}},

    {"when": {"axis":  "x|z", "state":  "floor_bottom_left"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_floor_bottom_left", "y":  180, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_bottom_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_left_floor_c", "y":  180, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_bottom_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_left_floor_f", "y":  180, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_bottom_right"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_floor_bottom_right", "y":  90, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_bottom_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_right_floor_c", "y":  90, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_bottom_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_bottom_right_floor_f", "y":  90, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_left"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_floor_top_left", "y":  270, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_left_floor_c", "y":  270, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_left"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_left_floor_f", "y":  270, "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_right"}, "apply": {"model": "portalmod:block/arbored_blackplate_panel_floor_top_right", "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_right_floor_c", "uvlock": true}},
    {"when": {"axis":  "x|z", "state":  "floor_top_right"}, "apply": {"model": "betterarbored:block/3/ab_corner_top_right_floor_f", "uvlock": true}}
  ]
}